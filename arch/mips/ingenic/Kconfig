config MACH_INGENIC_GENERIC
	bool
	select MACH_INGENIC
	select MACH_JZ4740
	select MACH_JZ4725B
	select MACH_JZ4770
	select MACH_JZ4780
	select MACH_X1000
	select MACH_X1830
	select MACH_X2000
	select MACH_T31
	select MACH_T41

choice
	prompt "Machine type"
	depends on MACH_INGENIC_SOC
	default INGENIC_GENERIC_BOARD

config INGENIC_GENERIC_BOARD
	bool "Generic board"
	select MACH_INGENIC_GENERIC

